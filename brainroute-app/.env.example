# BrainRoute Next.js public environment variables.
# Copy this file to .env.local and replace placeholders locally.

# Supabase browser configuration.
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-public-anon-key

# Optional Streamlit prediction tool URL.
NEXT_PUBLIC_STREAMLIT_APP_URL=https://brainroute.streamlit.app/

# Auth redirect base URL.
# Local:
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Production GitHub Pages example:
# NEXT_PUBLIC_SITE_URL=https://omicscodeathon.github.io/brainroutedb
